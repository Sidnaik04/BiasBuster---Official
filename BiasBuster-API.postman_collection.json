    {
      "name": "Bias Mitigation",
      "item": [
        {
          "name": "Mitigate Bias",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"upload_id\": 1,\n  \"target_column\": \"income\",\n  \"sensitive_columns\": [\"gender\"],\n  \"strategy_name\": \"threshold\",\n  \"strategy_config\": {\n    \"grid_size\": 200\n  },\n  \"confirm_recommendation\": true\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/bias/mitigate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "bias", "mitigate"]
            },
            "description": "Execute fully pipeline-aware bias mitigation. All metrics are computed internally from the dataset and model. Supported strategies: 'threshold', 'reweighting', 'smote'. If confirm_recommendation is false, returns confirmation_required status without executing mitigation. Returns comprehensive report with before/after metrics comparison and fairness-performance tradeoff analysis."
          },
          "response": []
        }
